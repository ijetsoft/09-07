extends layout_short

block content
  h2= title
  p Всего пользователей: #{totalCount}
  if lst && lst.length
    ul
      each user in lst
        li
          strong= user.firstName
          |  #{user.lastName}
          |  — #{user.email}
          |   #{user.createdAt}
  else
    p Пользователей нет.
